# ============================================================
# VentureNode — Backend Environment Template
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# ============================================================

# ---- Application ----
ENVIRONMENT=development
DEBUG=false

# ---- Notion Integration ----
# Get this from: https://www.notion.so/my-integrations
NOTION_TOKEN=secret_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Notion Database IDs
# Get each ID from the database URL in Notion (the 32-char hex string)
# Leave blank during Phase 1. Required before running agents in Phase 2.
NOTION_IDEAS_DB_ID=
NOTION_RESEARCH_DB_ID=
NOTION_ROADMAP_DB_ID=
NOTION_TASKS_DB_ID=
NOTION_REPORTS_DB_ID=

# ---- Groq LLM Inference ----
# Get this free from: https://console.groq.com
GROQ_API_KEY=gsk_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
GROQ_MODEL=llama-3.3-70b-versatile
GROQ_TEMPERATURE=0.2

# ---- CORS ----
# Comma-separated list of allowed origins for the Next.js frontend
CORS_ORIGINS=["http://localhost:3000"]

# ---- Rate Limiting ----
RATE_LIMIT_PER_MINUTE=60
