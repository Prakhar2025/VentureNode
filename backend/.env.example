# ============================================================
# VentureNode Backend Environment
# Place this file at: backend/.env
# Copy from .env.example and fill in your values.
# NEVER commit this file. It is in .gitignore.
# ============================================================

# ---- Application ----
ENVIRONMENT=development
DEBUG=false

# ---- Notion Integration ----
# Get from: https://www.notion.so/my-integrations → New Integration → Copy token
NOTION_TOKEN=secret_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ---- Notion Database IDs ----
# Needed in Phase 2 (before running agents). Leave blank for now.
# Get ID from the database URL:
# https://notion.so/workspace/[THIS-32-CHAR-ID]?v=...
NOTION_IDEAS_DB_ID=
NOTION_RESEARCH_DB_ID=
NOTION_ROADMAP_DB_ID=
NOTION_TASKS_DB_ID=
NOTION_REPORTS_DB_ID=

# ---- Groq LLM Inference ----
# Free from: https://console.groq.com → API Keys → Create API Key
GROQ_API_KEY=gsk_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
GROQ_MODEL=llama-3.3-70b-versatile
GROQ_TEMPERATURE=0.2

# ---- CORS (comma-separated allowed origins) ----
CORS_ORIGINS=["http://localhost:3000"]

# ---- Rate Limiting ----
RATE_LIMIT_PER_MINUTE=60
